{
  "name": "@clipfast/worker",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @clipfast/shared && tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "test": "vitest run --root ../.. apps/worker/src",
    "test:watch": "vitest --root ../.. apps/worker/src"
  },
  "dependencies": {
    "@clipfast/shared": "*",
    "bullmq": "^5.30.0",
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
